# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://ghosted:ghosted_secret@localhost:5432/ghosted?schema=public"

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ─── Backend API ────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
API_CORS_ORIGIN="http://localhost:3000"

# ─── Frontend ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth (Better Auth) ────────────────────────────────────────
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:4000"

# ─── File Storage (MinIO / S3) ──────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="ghosted_minio"
S3_SECRET_KEY="ghosted_minio_secret"
S3_BUCKET="ghosted-files"
S3_REGION="us-east-1"

# ─── Email ──────────────────────────────────────────────────────
# Leave empty to use console logger in development
RESEND_API_KEY=""
EMAIL_FROM="noreply@ghosted.dev"

# ─── Environment ────────────────────────────────────────────────
NODE_ENV="development"
